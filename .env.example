# ─────────────────────────────────────────
# Oracle Database Credentials (required)
# ─────────────────────────────────────────
ORACLE_USER=your_username
# If your password contains '#', wrap it in double quotes: "p@ss#word"
ORACLE_PASSWORD=your_password
# Format: hostname:port/service_name  e.g. db.example.com:1521/ORCL
ORACLE_CONNECTION_STRING=your_host:port/service_name

# ─────────────────────────────────────────
# Server (optional)
# ─────────────────────────────────────────
# Port the Express server listens on. Defaults to 5000.
# PORT=5000

# ─────────────────────────────────────────
# External API security (optional)
# ─────────────────────────────────────────
# Secret code required by the /api/external/movement-tracking gateway.
# Change this before going to production.
MOVEMENT_TRACKING_API_KEY=FALCON_SECURE_TRACE_2026

# ─────────────────────────────────────────
# Google Maps (optional — improves address quality)
# ─────────────────────────────────────────
# Used by /api/geocode to convert GPS coordinates into human-readable addresses.
# If not set, the server automatically falls back to OpenStreetMap Nominatim,
# which requires no key and works out-of-the-box — so location names will still
# appear correctly in map popups, the movement ledger, report tables, and CSV
# exports. Set this key if you prefer Google's higher-accuracy results.
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# ─────────────────────────────────────────
# Optional integrations
# ─────────────────────────────────────────
# Gemini API key — exposed to the frontend via Vite for any AI features.
# GEMINI_API_KEY=your_gemini_api_key
